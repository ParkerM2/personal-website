# Global security headers — applied to ALL paths
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https:;

# Hashed assets — cache forever (filename changes on content change)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML — never cache (must always get latest to pick up new hashed assets)
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Static assets in public/ — cache for 1 day
/*.svg
  Cache-Control: public, max-age=86400
/*.ico
  Cache-Control: public, max-age=86400
